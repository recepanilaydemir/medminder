# =============================================================================
# MedMinder Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Gemini API Key - Get yours at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Database path (optional, defaults to ./medminder.db)
DB_PATH=./medminder.db

# Server config
HOST=0.0.0.0
PORT=8000

# Debug mode (set to true for development)
DEBUG=false

# Google Calendar OAuth (optional)
GOOGLE_OAUTH_CREDENTIALS=./gcp-oauth.keys.json
